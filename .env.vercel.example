# Environment untuk Vercel
# Copy to Vercel Dashboard -> Environment Variables
# Jangan commit file dengan credential asli!
APP_NAME="RENPRO UPBU Budiarto"
APP_ENV=production
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=false
APP_URL=https://your-app.vercel.app

ASSET_URL=${APP_URL}

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Jakarta

DB_CONNECTION=pgsql
DB_URL=postgresql://user:password@host:5432/dbname?sslmode=require

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

CACHE_STORE=array
LOG_CHANNEL=stderr
LOG_LEVEL=error

FILESYSTEM_DISK=local
UPLOADS_DISK=local

MIGRATE_SECRET=generate-a-random-secret-here
NODE_ENV=production
COMPOSER_PROCESS_TIMEOUT=0
