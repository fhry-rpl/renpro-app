{
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "routes": [
        { "src": "/build/(.*)", "dest": "/public/build/$1" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ],
    "outputDirectory": "public",
    "buildCommand": "npm run build && php artisan config:cache && php artisan route:cache && php artisan view:cache",
    "installCommand": "npm install && composer install --no-dev --no-interaction --optimize-autoloader"
}
